<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.korea.test.mapper.MpMapper">

	<!-- 로그인 체크 -->
	<select id="loginCheck">
		select * from Customer where id = #{id}
	</select>


	<!-- 한 건 조회 -->
	<select id="selectList" resultType="mpVO">
		select * from Customer where idx = #{idx}
	</select>


	<!-- 회원 정보 수정 업데이트 -->
	<update id="customerInfo" parameterType="mpVO">
		update Customer set
			id = #{id},
			nickname = #{nickname},
			password = #{password},
			sysdate,
			phoneNumber = #{phoneNumber},
			email = #{email}
		where
			idx = #{idx}
	</update>

</mapper>










